@article{zhang_plug-and-play_2022,
  title = {Plug-and-{{Play Image Restoration With Deep Denoiser Prior}}},
  author = {Zhang, Kai and Li, Yawei and Zuo, Wangmeng and Zhang, Lei and Van Gool, Luc and Timofte, Radu},
  year = 2022,
