@article{guntoro_x-ray_2019,
  title = {X-Ray {{Microcomputed Tomography}} ({{\textmu CT}}) for {{Mineral Characterization}}: {{A Review}} of {{Data Analysis Methods}}},
  shorttitle = {X-Ray {{Microcomputed Tomography}} ({{\textmu CT}}) for {{Mineral Characterization}}},
  author = {Guntoro, Pratama and Ghorbani, Yousef and Koch, Pierre-Henri and Rosenkranz, Jan},
  year = 2019,
  month = mar,
  journal = {Minerals},
  volume = {9},
  number = {3},
  pages = {183},
  issn = {2075-163X},
  doi = {10.3390/min9030183},
  urldate = {2026-07-12},
  abstract = {The main advantage of X-ray microcomputed tomography (\textmu CT) as a non-destructive imaging tool lies in its ability to analyze the three-dimensional (3D) interior of a sample, therefore eliminating the stereological error exhibited in conventional two-dimensional (2D) image analysis. Coupled with the correct data analysis methods, \textmu CT allows extraction of textural and mineralogical information from ore samples. This study provides a comprehensive overview on the available and potentially useful data analysis methods for processing 3D datasets acquired with laboratory \textmu CT systems. Our study indicates that there is a rapid development of new techniques and algorithms capable of processing \textmu CT datasets, but application of such techniques is often sample-specific. Several methods that have been successfully implemented for other similar materials (soils, aggregates, rocks) were also found to have the potential to be applied in mineral characterization. The main challenge in establishing a \textmu CT system as a mineral characterization tool lies in the computational expenses of processing the large 3D dataset. Additionally, since most of the \textmu CT dataset is based on the attenuation of the minerals, the presence of minerals with similar attenuations limits the capability of \textmu CT in mineral segmentation. Further development on the data processing workflow is needed to accelerate the breakthrough of \textmu CT as an analytical tool in mineral characterization.},
  langid = {english},
  file = {/Users/thomas/Zotero/storage/D7WRHZDZ/Guntoro et al. - 2019 - X-ray Microcomputed Tomography (µCT) for Mineral Characterization A Review of Data Analysis Methods.pdf}
}

