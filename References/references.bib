  booktitle = {2021 {{IEEE}}/{{CVF International Conference}} on {{Computer Vision}} ({{ICCV}})},
  author = {Rumberger, Josef Lorenz and Yu, Xiaoyan and Hirsch, Peter and Dohmen, Melanie and Guarino, Vanessa Emanuela and Mokarian, Ashkan and Mais, Lisa and Funke, Jan and Kainmueller, Dagmar},
